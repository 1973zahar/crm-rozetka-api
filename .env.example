ROZETKA_API_BASE_URL=https://api-seller.rozetka.com.ua
ROZETKA_CONTENT_LANGUAGE=uk

# Необов'язково: шлях до Node.js, якщо команда node не доступна у PowerShell
ROZETKA_NODE_PATH=

# Варіант 1: готовий Bearer token
ROZETKA_API_TOKEN=

# Варіант 2: логін і пароль кабінету продавця
# Пароль mock-api.ps1 закодує в base64 перед POST /sites.
ROZETKA_USERNAME=
ROZETKA_PASSWORD=
