ROZETKA_API_BASE_URL=https://api-seller.rozetka.com.ua
ROZETKA_CONTENT_LANGUAGE=uk
ROZETKA_REQUEST_TIMEOUT_MS=20000

CRM_SQL_API_BASE_URL=http://192.168.0.166:3000
CRM_SQL_API_TIMEOUT_SEC=15
CRM_SQL_FULL_LIMIT=50000

# Необов'язково: шлях до Node.js, якщо команда node не доступна у PowerShell
ROZETKA_NODE_PATH=

# Варіант 1: готовий Bearer token
ROZETKA_API_TOKEN=

# Варіант 2: логін і пароль кабінету продавця
# Пароль mock-api.ps1 закодує в base64 перед POST /sites.
ROZETKA_USERNAME=
ROZETKA_PASSWORD=

# NovaPay real data gateway. The browser calls /api/novapay/payments; this server calls the URL below.
NOVAPAY_GATEWAY_URL=
NOVAPAY_GATEWAY_TOKEN=
NOVAPAY_GATEWAY_TOKEN_HEADER=Authorization
NOVAPAY_GATEWAY_TIMEOUT_SEC=20

# NovaPay business-cabinet credentials stay server-side only.
# These values are not used by app.js and must not be exposed to the browser.
NOVAPAY_BUSINESS_LOGIN=
NOVAPAY_REFRESH_TOKEN=
NOVAPAY_CERTIFICATE_PATH=.secrets/novapay-public.pem
NOVAPAY_EXPORT_EMAIL=
NOVAPAY_MERCHANT_ID=
NOVAPAY_CLIENT_API_URL=https://business.novapay.ua/Services/ClientAPIService.svc
NOVAPAY_CLIENT_ID=
NOVAPAY_ACCOUNT_ID=
NOVAPAY_ACCOUNT_IBAN=
NOVAPAY_DATE_TYPE=
NOVAPAY_HISTORY_FROM=2020-01-01
NOVAPAY_HISTORY_WINDOW_DAYS=31
NOVAPAY_HISTORY_THROTTLE_MS=700
NOVAPAY_CACHE_PATH=.cache/novapay-payments-cache.json
NOVAPAY_INCLUDE_ACCOUNT_EXTRACT=true
NOVAPAY_INCLUDE_REGISTERS=true
NOVAPAY_REGISTER_TYPES=1,2,3,4
NOVAPAY_REGISTER_FILE_EXTENSION=csv
NOVAPAY_REGISTER_DATE_FORMAT=dd.MM.yyyy
NOVAPAY_REGISTER_POLL_ATTEMPTS=4
NOVAPAY_REGISTER_POLL_SLEEP_MS=1500

# Nova Poshta tracking gateway. Keep the real key server-side only.
NOVA_POSHTA_API_URL=https://api.novaposhta.ua/v2.0/json/
NOVA_POSHTA_API_KEY=
NOVA_POSHTA_TIMEOUT_SEC=20
NOVA_POSHTA_HISTORY_FROM=2020-01-01
NOVA_POSHTA_HISTORY_WINDOW_DAYS=30
NOVA_POSHTA_CACHE_PATH=.cache/nova-poshta-documents-cache.json
NOVA_POSHTA_THROTTLE_MS=1200
